^.*\.Rproj$
^\.Rproj\.user$
^_output$
^\.quarto$

# Quarto Document files (chapters, notebooks)
^.*\.qmd$
^.*\.Rmd$
^.*\.nb\.html$
^_quarto\.yml$

# Cover and logo art (Document assets, not package assets)
^whittakerr_cover_art_text\.png$
^whittakerr_logo_art\.png$
^biome_example.*\.png$

# Project ideation and working notes
^background$
^images$

# User-side caches (not part of package distribution).
# WorldClim and GADM downloads land in cache/ at the project
# root; running get_climate() or map_biomes() recreates it.
^cache$

# Regenerable demo output (Whittakerr_3d.Rmd writes this)
^oregon_biomes\.kml$

# data-raw is by convention excluded from the built package
^data-raw$

# Stray dotfiles
^\.gitignore$
^\.DS_Store$
^\.Rhistory$
^\.RData$

# README-style files we may add later
^README\.Rmd$
^cran-comments\.md$
^\.positai$
^\.claude$
